{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "bref/bref": "^2.4",
        "bref/extra-php-extensions": "^1.7",
        "bref/laravel-bridge": "^3.0",
        "bugsnag/bugsnag-laravel": "^2.0",
        "chillerlan/php-qrcode": "^5.0",
        "eightcedars/filament-inactivity-guard": "^1.0",
        "fakerphp/faker": "^1.23",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "flowframe/laravel-trend": "^0.4.0",
        "gerenuk/filament-banhammer": "dev-dependabot/composer/filament/filament-tw-5.4",
        "guava/calendar": "^3.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^12",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-path-prefixing": "^3.0",
        "mchev/banhammer": "^2.4",
        "owen-it/laravel-auditing": "^14",
        "php-open-source-saver/jwt-auth": "^2.1",
        "spatie/laravel-permission": "^6.1",
        "stripe/stripe-php": "^17",
        "tailflow/laravel-orion": "^2",
        "tapp/filament-auditing": "^4.0"
    },
    "require-dev": {
        "agencetwogether/hookshelper": "^0.1.0",
        "barryvdh/laravel-debugbar": "^3.15",
        "barryvdh/laravel-ide-helper": "^3.5",
        "brianium/paratest": "^7.3",
        "dutchcodingcompany/filament-developer-logins": "^2.1",
        "ergebnis/phpstan-rules": "^2.6",
        "filament/upgrade": "^5.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Guava\\FilamentNestedResources\\": "stubs/Guava/FilamentNestedResources/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pre-autoload-dump": [
            "Aws\\Script\\Composer\\Composer::removeUnusedServices"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "guava/calendar"
            ]
        },
        "aws/aws-sdk-php": [
            "Sqs",
            "Ses"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
